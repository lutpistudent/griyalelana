APP_NAME="Griya Lelana"
APP_ENV=production
APP_KEY=base64:PASTE_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://griyalelana.vercel.app
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
# Use a public/managed PostgreSQL connection such as Neon. Do not use 127.0.0.1 or localhost on Vercel.
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require
DB_CHANNEL_BINDING=require

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=array
CACHE_PREFIX=
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Griya Lelana"

CLOUDINARY_URL=
CLOUDINARY_UPLOAD_PRESET=

XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
XENDIT_IS_PRODUCTION=true
XENDIT_INVOICE_DURATION=86400
XENDIT_SUCCESS_REDIRECT_URL=https://griyalelana.vercel.app/dashboard
XENDIT_FAILURE_REDIRECT_URL=https://griyalelana.vercel.app/dashboard
XENDIT_SHOULD_SEND_EMAIL=false

LARAVEL_STORAGE_PATH=/tmp/storage
VIEW_COMPILED_PATH=/tmp/storage/framework/views
APP_CONFIG_CACHE=/tmp/storage/bootstrap/cache/config.php
APP_EVENTS_CACHE=/tmp/storage/bootstrap/cache/events.php
APP_PACKAGES_CACHE=/tmp/storage/bootstrap/cache/packages.php
APP_ROUTES_CACHE=/tmp/storage/bootstrap/cache/routes.php
APP_SERVICES_CACHE=/tmp/storage/bootstrap/cache/services.php
SSR_TEMP_PATH=/tmp/ssr

VITE_APP_NAME="Griya Lelana"
